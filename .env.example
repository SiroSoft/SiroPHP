APP_NAME="Siro API Framework"
APP_ENV=local
APP_DEBUG=true
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_TRUSTED_PROXIES=

JWT_SECRET=change_this_to_a_strong_secret_with_at_least_32_characters
JWT_TTL=3600
JWT_REFRESH_TTL=604800
THROTTLE_FALLBACK=file

CACHE_DRIVER=file
CACHE_TTL=60
CACHE_PREFIX=siro:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=0.2

CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Database Configuration
# Option 1: SQLite (recommended for development/testing)
DB_CONNECTION=sqlite
# DB_DATABASE should be an absolute path or relative to project root
# Example: ./storage/database.sqlite or /var/www/html/storage/database.sqlite
DB_DATABASE=storage/database.sqlite

# Option 2: MySQL/MariaDB (for production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=siro
# DB_USERNAME=root
# DB_PASSWORD=

DB_CHARSET=utf8mb4
DB_SLOW_QUERY_THRESHOLD=100

# Logging
LOG_RETENTION_DAYS=30

# Mail
MAIL_DRIVER=sendmail
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=user
# MAIL_PASSWORD=pass
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME="Siro API"

# Queue
# QUEUE_DRIVER=database
# QUEUE_DEFAULT_MAX_ATTEMPTS=3

# Storage
STORAGE_DRIVER=local
STORAGE_PATH=storage/app
# STORAGE_DRIVER=s3
# STORAGE_S3_KEY=your-key
# STORAGE_S3_SECRET=your-secret
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=my-bucket
# STORAGE_S3_ENDPOINT=
