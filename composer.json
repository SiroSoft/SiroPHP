{
    "name": "sirosoft/api",
    "description": "Siro API Framework Application Skeleton - Build production-ready APIs in minutes. Built-in JWT auth, CRUD generator, 62 CLI commands, Swagger UI.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "framework",
        "api",
        "micro-framework",
        "php",
        "core",
        "rest",
        "rest-api",
        "jwt",
        "auth",
        "crud-generator",
        "api-first",
        "php8"
    ],
    "homepage": "https://github.com/SiroSoft/SiroPHP",
    "support": {
        "issues": "https://github.com/SiroSoft/SiroPHP/issues",
        "source": "https://github.com/SiroSoft/SiroPHP"
    },
    "require": {
        "php": ">=8.2",
        "sirosoft/core": "^0.26.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php siro key:generate || true"
        ],
        "benchmark:ci": "@php scripts/benchmark-ci.php",
        "sbom": "@php scripts/generate-sbom.php",
        "audit:supply-chain": "@php scripts/audit-supply-chain.php",
        "health": "@php scripts/health-check.php",
        "docs:generate": "@php scripts/generate-docs.php",
        "release:check": [
            "@php scripts/release-check.php --ci"
        ],
        "release:check:strict": [
            "@php scripts/release-check.php --strict --with-prod-doctor"
        ]
    },
    "bin": [
        "siro"
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "11.5.50",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "suggest": {
        "ext-redis": "Required for Redis cache, session, and rate limiter drivers",
        "ext-openssl": "Required for Encrypter (AES-256 encryption)",
        "ext-curl": "Required for HTTP Client (Http::get/post/...)"
    }
}
