/vendor/
/.env
/composer.lock

/storage/cache/*
!/storage/cache/.gitkeep

/storage/logs/*
!/storage/logs/.gitkeep

/storage/rate_limit/*
/storage/*.db

# Generated API documentation (kept locally only)
/openapi.json
/postman_collection.json
*.csv

# Documentation source (tracked)
!/docs/openapi/
!/docs/postman/
!/docs/swagger/

# Archive documentation (kept locally only)
/docs/archive/

# IDE and AI assistant folders (kept locally only)
/.cline/
.vscode/
.idea/

# Assistant-generated test files (kept locally only)
/tests/*_test.php
!/tests/unit/

# Generated files in public (kept locally only)
/public/openapi.json
/public/docs.html

.DS_Store
Thumbs.db
