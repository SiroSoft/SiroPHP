APP_NAME="Siro API Framework"
APP_ENV=local
APP_DEBUG=true
APP_TRUSTED_PROXIES=

JWT_SECRET=change_this_to_a_strong_secret_with_at_least_32_characters
JWT_TTL=3600
THROTTLE_FALLBACK=file

CACHE_DRIVER=file
CACHE_TTL=60
CACHE_PREFIX=siro:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=0.2

CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=siro
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
