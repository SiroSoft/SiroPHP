APP_NAME="Siro API Framework"
APP_ENV=testing
APP_DEBUG=true
APP_TRUSTED_PROXIES=

JWT_SECRET=test_secret_for_integration_testing_only_32chars!
JWT_TTL=3600
THROTTLE_FALLBACK=file

CACHE_DRIVER=file
CACHE_TTL=60
CACHE_PREFIX=siro:test:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=0.2

CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Use SQLite for testing (no MySQL server needed)
DB_CONNECTION=sqlite
DB_DATABASE=storage/test.db
DB_CHARSET=utf8mb4
