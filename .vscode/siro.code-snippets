{
	"Siro CRUD Controller": {
		"prefix": "siro-controller",
		"body": [
			"<?php",
			"",
			"declare(strict_types=1);",
			"",
			"namespace App\\Controllers;",
			"",
			"use App\\Resources\\${1:Resource}Resource;",
			"use App\\Services\\${2:${1}}Service;",
			"use Siro\\Core\\Controller;",
			"use Siro\\Core\\Request;",
			"use Siro\\Core\\Response;",
			"",
			"final class ${1}Controller extends Controller",
			"{",
			"    public function __construct(private readonly ${2}Service \$service)",
			"    {",
			"    }",
			"",
			"    public function index(Request \$request): Response",
			"    {",
			"        \$result = \$this->service->getAll(",
			"            \$request->queryInt('page', 1),",
			"            \$request->queryInt('per_page', 20)",
			"        );",
			"        return \$this->paginated(",
			"            ${1}Resource::collection(\$result['data']),",
			"            \$result['meta'],",
			"            '${1} list'",
			"        );",
			"    }",
			"",
			"    public function show(Request \$request): Response",
			"    {",
			"        \$id = (int) \$request->param('id');",
			"        if (\$id <= 0) return \$this->error('Invalid id', 422);",
			"        \$item = \$this->service->getById(\$id);",
			"        if (\$item === null) return \$this->error('${1} not found', 404);",
			"        return \$this->success(${1}Resource::make(\$item), '${1} detail');",
			"    }",
			"",
			"    public function store(Request \$request): Response",
			"    {",
			"        \$data = \$request->validate([",
			"            '${3:name}' => 'required|min:2|max:255',",
			"        ]);",
			"        \$item = \$this->service->create(\$data);",
			"        return \$this->created(${1}Resource::make(\$item), '${1} created');",
			"    }",
			"",
			"    public function update(Request \$request): Response",
			"    {",
			"        \$id = (int) \$request->param('id');",
			"        if (\$id <= 0) return \$this->error('Invalid id', 422);",
			"        \$data = \$request->validate([",
			"            '${4:name}' => 'min:2|max:255',",
			"        ]);",
			"        \$item = \$this->service->update(\$id, \$data);",
			"        if (\$item === null) return \$this->error('${1} not found', 404);",
			"        return \$this->success(${1}Resource::make(\$item), '${1} updated');",
			"    }",
			"",
			"    public function delete(Request \$request): Response",
			"    {",
			"        \$id = (int) \$request->param('id');",
			"        if (\$id <= 0) return \$this->error('Invalid id', 422);",
			"        return \$this->service->delete(\$id)",
			"            ? \$this->noContent()",
			"            : \$this->error('${1} not found', 404);",
			"    }",
			"}"
		],
		"description": "Siro CRUD Controller with validation"
	},
