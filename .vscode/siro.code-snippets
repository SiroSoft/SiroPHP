	"Siro Service": {
		"prefix": "siro-service",
		"body": [
			"<?php",
			"",
			"declare(strict_types=1);",
			"",
			"namespace App\\Services;",
			"",
			"use App\\Repositories\\${1:Model}Repository;",
			"",
			"final class ${1:Model}Service",
			"{",
			"    public function __construct(private readonly ${1}Repository \$repository)",
			"    {",
			"    }",
			"",
			"    public function getAll(int \$page = 1, int \$perPage = 20): array",
			"    {",
			"        return \$this->repository->findAll(\$page, \$perPage);",
			"    }",
			"",
			"    public function getById(int \$id): ?array",
			"    {",
			"        return \$this->repository->findById(\$id);",
			"    }",
			"",
			"    public function create(array \$data): array",
			"    {",
			"        return \$this->repository->store(\$data);",
			"    }",
			"",
			"    public function update(int \$id, array \$data): ?array",
			"    {",
			"        return \$this->repository->update(\$id, \$data);",
			"    }",
			"",
			"    public function delete(int \$id): bool",
			"    {",
			"        return \$this->repository->destroy(\$id);",
			"    }",
			"}"
		],
		"description": "Siro Service Layer"
	},
	"Siro Repository": {
		"prefix": "siro-repository",
		"body": [
			"<?php",
			"",
			"declare(strict_types=1);",
			"",
			"namespace App\\Repositories;",
			"",
			"use App\\Models\\${1:Model};",
			"",
			"final class ${1}Repository",
			"{",
			"    public function findAll(int \$page = 1, int \$perPage = 20): array",
			"    {",
			"        return ${1}::paginate(\$perPage, \$page);",
			"    }",
			"",
			"    public function findById(int \$id): ?array",
			"    {",
			"        \$model = ${1}::find(\$id);",
			"        return \$model?->toArray();",
			"    }",
			"",
			"    public function store(array \$data): array",
			"    {",
			"        return ${1}::create(\$data)->toArray();",
			"    }",
			"",
			"    public function update(int \$id, array \$data): ?array",
			"    {",
			"        \$model = ${1}::find(\$id);",
			"        if (\$model === null) return null;",
			"        \$model->update(\$data);",
			"        return \$model->fresh()?->toArray();",
			"    }",
			"",
			"    public function destroy(int \$id): bool",
			"    {",
			"        \$model = ${1}::find(\$id);",
			"        if (\$model === null) return false;",
			"        return \$model->delete();",
			"    }",
			"}"
		],
		"description": "Siro Repository Layer"
	},
